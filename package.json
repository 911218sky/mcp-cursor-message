{
	"name": "mcp-cursor-message",
	"displayName": "mcp-cursor-message",
	"description": "MCP side-channel chat: sidebar queue, check_messages / ask_question; Cursor integration.",
	"version": "9.3.19",
	"author": "911218sky",
	"publisher": "911218sky",
	"keywords": [
		"mcp",
		"model context protocol",
		"cursor",
		"chat",
		"sidebar",
		"queue",
		"assistant",
		"copilot",
		"workflow"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/911218sky/mcp-cursor-message.git"
	},
	"license": "AGPL-3.0",
	"packageManager": "bun@1.2.17",
	"engines": {
		"vscode": "^1.105.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "mcpMessenger",
					"title": "MCP chat",
					"icon": "media/icon.svg"
				}
			]
		},
		"views": {
			"mcpMessenger": [
				{
					"type": "webview",
					"id": "mcp-cursor-message",
					"name": "Messages & queue"
				}
			]
		},
		"commands": [
			{
				"command": "mcpMessenger.setupMcp",
				"title": "mcp-cursor-message: Install MCP configuration"
			},
			{
				"command": "mcpMessenger.removeMcp",
				"title": "mcp-cursor-message: Remove MCP configuration"
			},
			{
				"command": "mcpMessenger.checkForUpdates",
				"title": "mcp-cursor-message: Check for updates (GitHub)"
			}
		],
		"configuration": {
			"title": "MCP chat",
			"properties": {
				"mcpMessenger.uiLanguage": {
					"type": "string",
					"enum": [
						"en",
						"zh",
						"auto"
					],
					"default": "en",
					"description": "Sidebar Webview UI language. Default English; auto follows the editor display language."
				},
				"mcpMessenger.updateCheck.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Check GitHub Releases for newer versions and offer to download/install the VSIX."
				},
				"mcpMessenger.updateCheck.intervalHours": {
					"type": "number",
					"default": 12,
					"minimum": 1,
					"description": "How often to check GitHub Releases for updates (hours)."
				},
				"mcpMessenger.updateCheck.startupDelaySeconds": {
					"type": "number",
					"default": 15,
					"minimum": 0,
					"description": "Delay before the first update check after startup (seconds). Set to 0 to check immediately."
				},
				"mcpMessenger.updateCheck.repo": {
					"type": "string",
					"default": "911218sky/mcp-cursor-message",
					"description": "GitHub repo in owner/name form used for update checks."
				}
			}
		}
	},
	"scripts": {
		"compile:mcp": "node esbuild.config.mjs mcp",
		"compile:ext": "node esbuild.config.mjs ext",
		"compile": "node esbuild.config.mjs all",
		"package": "bun run compile && bunx @vscode/vsce package --no-dependencies --allow-missing-repository"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.28.0",
		"dompurify": "^3.3.3",
		"marked": "^17.0.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/dompurify": "^3.2.0",
		"@types/node": "^25.5.0",
		"@types/vscode": "^1.105.0",
		"@vscode/vsce": "^3.7.1",
		"esbuild": "^0.27.4",
		"typescript": "^6.0.2"
	}
}
